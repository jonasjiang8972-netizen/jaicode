{
  "name": "@jaicode/tui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/main.tsx",
  "scripts": {
    "dev": "bun run src/main.tsx",
    "build:mac": "bun build --compile --target=bun-darwin-x64 --outfile=dist/jaicode-macos src/main.tsx",
    "build:win": "bun build --compile --target=bun-windows-x64 --outfile=dist/jaicode-win.exe src/main.tsx",
    "build:all": "bun run build:mac && bun run build:win"
  },
  "dependencies": {
    "@jaicode/core": "*",
    "@jaicode/llm": "*",
    "@jaicode/i18n": "*",
    "ink": "^5.1.0",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "chalk": "^5.3.0",
    "diff": "^7.0.0",
    "marked": "^14.1.0",
    "marked-terminal": "^7.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/diff": "^7.0.0",
    "@types/marked-terminal": "^6.0.0",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
