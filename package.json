{
  "name": "@jaicode/monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Jaicode - Local-first AI coding agent CLI",
  "packageManager": "bun@1.3.14",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "dev": "bun run --cwd packages/cli src/index.ts",
    "build": "bun run --cwd packages/cli build",
    "typecheck": "bun run --cwd packages/cli typecheck",
    "test": "bun run --cwd packages/cli test",
    "lint": "echo 'lint placeholder'"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "ai": "^4.0.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0"
  }
}
